# Copie para .env e preencha com valores reais. Nunca commite o arquivo .env.
# Referência completa das variáveis suportadas pelo FinanceDash.

# --- Banco de dados ---
DATABASE_URL=jdbc:postgresql://localhost:5432/financedash
DATABASE_USERNAME=financedash
DATABASE_PASSWORD=financedash

# --- Servidor ---
SERVER_PORT=8080
PUBLIC_BASE_URL=http://localhost:8080

# --- Autenticação JWT ---
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRATION_SECONDS=86400

# --- Auth (opcional) ---
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_MINUTES=15
AUTH_PASSWORD_RESET_EXPIRATION_HOURS=2
AUTH_EMAIL_VERIFICATION_EXPIRATION_HOURS=48
AUTH_REFRESH_TOKEN_EXPIRATION_DAYS=30

# --- IA do Radar (opcional) ---
# Use "none" para manter o copiloto determinístico sem OpenAI.
SPRING_AI_CHAT_MODEL=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Billing Asaas ---
# Com ASAAS_ENABLED=true, api-key, base-url e webhook-token são obrigatórios (fail-fast no startup).
ASAAS_ENABLED=false
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=
ASAAS_PRO_PLAN_VALUE=29.90

# --- E-mail (Resend) ---
# Railway Hobby bloqueia SMTP (porta 587). Use a API HTTP (padrao: MAIL_PROVIDER=resend).
# 1) Crie conta em https://resend.com
# 2) API Keys → crie uma key (re_...)
# 3) Sem domínio verificado: MAIL_FROM=onboarding@resend.dev (só envia para seu e-mail de teste)
# 4) Com domínio verificado: MAIL_FROM=noreply@seudominio.com
# No Railway, NAO use dominio railway.app no from e evite < > na variavel.
MAIL_ENABLED=false
MAIL_PROVIDER=resend
RESEND_API_KEY=re_COLE_SUA_API_KEY_AQUI
MAIL_FROM=onboarding@resend.dev
PUBLIC_BASE_URL=http://localhost:8080

# SMTP local (opcional; nao funciona no Railway Hobby):
# MAIL_PROVIDER=smtp
# SPRING_MAIL_HOST=smtp.resend.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=resend
# SPRING_MAIL_PASSWORD=re_COLE_SUA_API_KEY_AQUI
# SPRING_MAIL_SMTP_AUTH=true
# SPRING_MAIL_SMTP_STARTTLS_ENABLE=true

# --- Radar (opcional) ---
# RADAR_TIMEZONE=America/Sao_Paulo
# RADAR_DIGEST_ENABLED=true
# RADAR_AI_ENABLED=false
